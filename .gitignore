
# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key

# Local environment (machine-specific secrets and paths)
.envrc

# mise per-machine overrides (mise.toml is committed; this is local-only)
mise.local.toml

# LuaRocks project-local tree (seeded by mise enter hook)
.luarocks/

# bv (beads viewer) local config and caches
.bv/

# scdoc-built manpages (sources are .scd; built artifacts ignored)
sandbox/man/*.[1-8]
claude/scripts/*/man/*.[1-8]

# Python (DEC-019: uv-managed project)
.venv/
__pycache__/
*.py[cod]
.ruff_cache/
.mypy_cache/
.pytest_cache/
dist/
build/
*.egg-info/
