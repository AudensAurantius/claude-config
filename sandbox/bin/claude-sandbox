#!/usr/bin/env bash
# claude-sandbox — run `claude` inside a kernel-enforced sandbox, in one of
# two modes (DEC-011):
#
#   composed (default)   sudo -u claude-session <scrub> srt claude ...
#                        srt provides the bwrap/Seatbelt layer + app-layer
#                        policy (settings emitted by 40s.15.2); claude-config
#                        contributes the identity layer (DEC-012) and, later,
#                        egress mediation (DEC-013).
#
#   --standalone         sudo -u claude-session <scrub> bwrap <args> -- claude
#                        claude-config builds the bwrap layer directly from
#                        the profile YAML (40s.15.3), no srt. For environments
#                        where srt is unavailable/untrusted, and for learning.
#
# Both modes share the host-side prep and the DEC-012 identity switch. Only
# the inner sandbox-doer differs.
#
# Cross-references:
#   DEC-006  allow-list visibility
#   DEC-007  bwrap as the sandbox primitive (used by both srt and standalone)
#   DEC-011  augmentation layer: composed (srt) default, standalone fallback
#   DEC-012  claude-session UID is the identity boundary (sudo -u, not --uid remap)
#   DEC-013  egress mediation (broker + SNI proxy) — wired in a later bead
#
# Usage: claude-sandbox [--standalone] [--profile NAME] [--dry-run] [--] [claude-args...]
#        claude-sandbox --oauth        # one-time claude-session OAuth bootstrap
#        claude-sandbox --version
#        claude-sandbox --help
#
# Options:
#   --standalone     use the direct-bwrap path instead of srt (DEC-011 fallback)
#   --oauth          one-time OAuth bootstrap for claude-session: runs its own
#                    claude bare (no srt/bwrap — login domains aren't on the
#                    sandbox allowlist) with cwd FORCED to claude-session's home,
#                    so no caller-inherited cwd is ever exposed (40s.15.10).
#                    Requires the claude-session user. Complete the browser flow;
#                    the token lands in claude-session's ~/.claude/.credentials.json.
#   --profile NAME   profile to load (default: "default")
#                    looked up at $CLAUDE_SANDBOX_PROFILE_DIR/NAME.yaml
#   --dry-run        print the resolved identity + exec line and exit; do not run
#   --version        print claude-sandbox + bwrap + srt + claude versions
#   --help, -h       show this help
#
# Cwd guard (40s.15.10): composed/standalone refuse to run from the home root
# or a ~/.dotfile/config dir (sandboxing such a cwd would expose it to
# claude-session). cd into a real project before invoking.
#
# Environment:
#   CLAUDE_SANDBOX_PROFILE_DIR   override the profile lookup path
#                                (default: ~/.config/claude-sandbox/profiles)
#   CLAUDE_SANDBOX_SKIP_VERSION_SYNC  set to skip the pre-session sync of
#                                claude-session's claude to the host version
#                                (40s.15.7) — useful offline or to avoid a
#                                native-binary re-download chasing host bumps.
#   CLAUDE_SANDBOX_SRT_SETTINGS  operator-provided srt --settings file for
#                                composed mode, used as-is (operator ensures
#                                the claude-session UID can read it). If unset,
#                                composed mode generates settings from the
#                                active profile via claude-sandbox-emit-srt-
#                                settings into a /tmp path readable by
#                                claude-session.
#
# Identity (DEC-012):
#   The wrapper runs as the host user, does host-side prep, then switches to
#   the claude-session UID via `sudo -u claude-session` before running srt or
#   bwrap. This yields kernel-enforced inter-process isolation and a readable
#   audit trail (journalctl _UID=claude-session). In production the switch is
#   authorized by /etc/sudoers.d/claude-sandbox (NOPASSWD for the specific
#   invocation). If claude-session does not exist (or sudo is unavailable),
#   the wrapper runs in same-UID degraded mode with a warning — still inside
#   the sandbox, but without the separate-principal guarantee.

set -euo pipefail

# ── Defaults / arg parsing ────────────────────────────────────────────────────

MODE="composed"          # composed | standalone | oauth
PROFILE_NAME="default"
DRY_RUN=false
PROFILE_DIR="${CLAUDE_SANDBOX_PROFILE_DIR:-$HOME/.config/claude-sandbox/profiles}"
# Operator override: if set, used as-is (operator ensures claude-session can
# read it). If unset, composed mode generates settings from the profile via
# the emitter into a /tmp path the claude-session UID can read.
SRT_SETTINGS_OVERRIDE="${CLAUDE_SANDBOX_SRT_SETTINGS:-}"
SELF_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
EMITTER="$SELF_DIR/claude-sandbox-emit-srt-settings"

# Per-project ACL granter (ClaudeConfig-40s.15.9). Resolve across the
# installed layout ($PREFIX/share/claude-sandbox/scripts) and the repo layout
# (sandbox/scripts); CLAUDE_SANDBOX_ACL_SCRIPT overrides.
resolve_acl_script() {
    local c
    for c in "${CLAUDE_SANDBOX_ACL_SCRIPT:-}" \
             "$SELF_DIR/../share/claude-sandbox/scripts/setup-claude-session-acls.sh" \
             "$SELF_DIR/../scripts/setup-claude-session-acls.sh"; do
        [ -n "$c" ] && [ -x "$c" ] && { echo "$c"; return 0; }
    done
    return 1
}

# Version-sync (ClaudeConfig-40s.15.7, DEC-016): before a session, bump
# claude-session's claude to an EXACT replica of the host user's version if it
# is behind (claude-session's auto-updater is off, so it does not drift on its
# own; the host user's does). Runs host-side as the wrapper user; the install
# is network-bound and re-downloads the native binary, so it only fires when
# actually behind, and is skippable via CLAUDE_SANDBOX_SKIP_VERSION_SYNC=1
# (offline / avoid chasing frequent host bumps).
behind() {  # behind A B -> true if A sorts strictly lower than B
    [ "$1" != "$2" ] && [ "$(printf '%s\n%s\n' "$1" "$2" | sort -V | head -1)" = "$1" ]
}
# Launch-time assembly (ClaudeConfig-40s.15.8, DEC-016): mirror the host
# user's ~/.claude/{skills,agents,commands,scripts} into claude-session's OWN
# ~/.claude so both modes see them — composed reads the real home, standalone
# binds it via sandbox_home. The host's 0700 home means claude-session can't
# read it directly, so the wrapper (running as the host user) stages to a
# world-readable /tmp dir, then claude-session mirrors that into its home.
# Phase-1 baseline = full mirror; omit/override is 40s.15.8.1.
CLAUDE_DENY_RULES_JSON='["Read(**/.env)","Read(**/.env.*)","Read(**/*.pem)","Read(**/*.key)","Read(**/id_rsa*)","Read(**/id_ed25519*)","Read(**/id_ecdsa*)","Read(**/credentials.json)","Read(**/.aws/**)","Read(**/.ssh/**)"]'
assemble_claude_dir() {
    local stage d
    stage="${TMPDIR:-/tmp}/claude-sandbox-claudedir.$(id -u)"
    rm -rf "$stage"; mkdir -p "$stage"
    for d in skills agents commands scripts; do
        [ -d "$USER_HOME/.claude/$d" ] && cp -r "$USER_HOME/.claude/$d" "$stage/$d"
    done
    chmod -R a+rX "$stage" 2>/dev/null || true
    for d in skills agents commands scripts; do
        if [ -d "$stage/$d" ]; then
            sudo -u "$SANDBOX_USER" -H bash -c \
                'mkdir -p "$HOME/.claude" && rsync -a --delete "$1/" "$HOME/.claude/$2/"' _ "$stage/$d" "$d" \
                || echo "claude-sandbox: warning — failed to mirror ~/.claude/$d to $SANDBOX_USER" >&2
        fi
    done
    rm -rf "$stage"
    # claude-session-scoped Claude Code permission deny rules (40s.16 re-home):
    # app-layer matcher where **/.env etc. DO work; scoped to claude-session so
    # the host user's interactive sessions are unaffected. Merged, idempotent.
    sudo -u "$SANDBOX_USER" -H bash -c '
        f="$HOME/.claude/settings.json"; mkdir -p "$HOME/.claude"
        if [ -f "$f" ]; then
            t=$(mktemp); jq --argjson d "$1" ".permissions = (.permissions // {}) + {deny: \$d}" "$f" > "$t" && mv "$t" "$f"
        else
            jq -n --argjson d "$1" "{permissions: {deny: \$d}}" > "$f"
        fi' _ "$CLAUDE_DENY_RULES_JSON" \
        || echo "claude-sandbox: warning — failed to set deny rules for $SANDBOX_USER" >&2
}

sync_claude_session_version() {
    local host_v cs_v
    host_v="$(basename "$(readlink -f "$USER_HOME/.local/bin/claude" 2>/dev/null)" 2>/dev/null)"
    printf '%s' "$host_v" | grep -qE '^[0-9]+\.[0-9]+\.[0-9]+$' || return 0
    cs_v="$(sudo -u "$SANDBOX_USER" -H env PATH="$SANDBOX_HOME/.local/bin:/usr/bin:/bin" \
        claude --version 2>/dev/null | grep -oE '[0-9]+\.[0-9]+\.[0-9]+' | head -1 || true)"
    if [ -z "$cs_v" ]; then
        echo "claude-sandbox: warning — could not read ${SANDBOX_USER}'s claude version; skipping sync" >&2
        return 0
    fi
    if behind "$cs_v" "$host_v"; then
        echo "claude-sandbox: ${SANDBOX_USER} claude $cs_v is behind host $host_v; syncing (exact pin)…" >&2
        if sudo -u "$SANDBOX_USER" -H env PATH="$SANDBOX_HOME/.local/bin:/usr/bin:/bin" \
            claude install "$host_v" >/dev/null 2>&1; then
            echo "claude-sandbox: ${SANDBOX_USER} claude synced to $host_v" >&2
        else
            echo "claude-sandbox: warning — claude sync to $host_v failed (offline?); continuing on $cs_v" >&2
        fi
    fi
    # bun: native claude is self-contained (DEC-016), so claude-session usually
    # has no bun. Only relevant once bunx-based MCP is added; flag a mismatch
    # rather than auto-upgrading to latest (which would break the exact-pin).
    if sudo -u "$SANDBOX_USER" -H env PATH="$SANDBOX_HOME/.bun/bin:/usr/bin:/bin" \
        command -v bun >/dev/null 2>&1; then
        local host_bun cs_bun
        host_bun="$("$USER_HOME/.bun/bin/bun" --version 2>/dev/null || true)"
        cs_bun="$(sudo -u "$SANDBOX_USER" -H env PATH="$SANDBOX_HOME/.bun/bin:/usr/bin:/bin" \
            bun --version 2>/dev/null || true)"
        if [ -n "$host_bun" ] && [ -n "$cs_bun" ] && behind "$cs_bun" "$host_bun"; then
            echo "claude-sandbox: note — ${SANDBOX_USER} bun $cs_bun < host $host_bun; manual pin needed (no exact-bun sync yet)" >&2
        fi
    fi
}

usage() {
    sed -n '/^# claude-sandbox/,/^# the separate-principal guarantee\./p' "${BASH_SOURCE[0]}" \
        | sed 's/^# \{0,1\}//'
}

while [ $# -gt 0 ]; do
    case "$1" in
        --standalone) MODE="standalone"; shift ;;
        --oauth)      MODE="oauth"; shift ;;
        --profile)    PROFILE_NAME="$2"; shift 2 ;;
        --dry-run)    DRY_RUN=true; shift ;;
        --help|-h)    usage; exit 0 ;;
        --version)
            echo "claude-sandbox 0.2.0 (Phase 1, two-mode)"
            bwrap --version 2>/dev/null || echo "bwrap: not installed"
            srt --version 2>/dev/null | sed 's/^/srt /' || echo "srt: not installed"
            claude --version 2>/dev/null || echo "claude: not installed"
            exit 0 ;;
        --)           shift; break ;;
        *)            break ;;   # rest is claude's; see --help for forcing
    esac
done
# Remaining "$@" are claude args.

# ── Preconditions ─────────────────────────────────────────────────────────────

PROFILE="${PROFILE_DIR}/${PROFILE_NAME}.yaml"
[ -f "$PROFILE" ] || { echo "claude-sandbox: profile not found: $PROFILE" >&2; exit 1; }

require() {
    command -v "$1" >/dev/null 2>&1 || {
        echo "claude-sandbox: required tool not on PATH: $1" >&2; exit 1; }
}
require yq; require jq; require getent
case "$MODE" in
    standalone) require bwrap ;;
    composed)   require srt ;;
    oauth)      : ;;  # bare cwd-controlled claude; needs neither bwrap nor srt
esac

# ── Host-side prep ────────────────────────────────────────────────────────────

USER_HOME="$HOME"
INHERIT_TERM="${TERM:-xterm-256color}"
INHERIT_LANG="${LANG:-C.UTF-8}"
ACTIVE_PROJECT="$PWD"

# Cwd guard (ClaudeConfig-40s.15.10): refuse to sandbox the home root or a
# ~/.dotfile/config dir. Sandboxing such a cwd would --chdir there and grant
# claude-session access to it (the inherited-cwd class of leak). Normal project
# dirs (~/Source/..., /srv/..., a project's .worktrees/<x>) are unaffected —
# only a FIRST path component starting with '.' directly under the home trips
# it. Composed/standalone only; oauth forces claude-session's own home.
assert_safe_cwd() {
    if [ "$ACTIVE_PROJECT" = "$USER_HOME" ]; then
        echo "claude-sandbox: refusing to sandbox the home root ($ACTIVE_PROJECT) — cd into a project." >&2
        exit 1
    fi
    case "$ACTIVE_PROJECT" in
        "$USER_HOME"/.*)
            echo "claude-sandbox: refusing to sandbox a dotfile/config dir: $ACTIVE_PROJECT" >&2
            echo "  Sandboxing here would grant claude-session access to it (inherited-cwd risk, 40s.15.10)." >&2
            echo "  cd into a real project directory and re-run." >&2
            exit 1 ;;
    esac
}
if [ "$MODE" != "oauth" ]; then assert_safe_cwd; fi

# Resolve the identity switch (DEC-012). Degrade gracefully for testability.
SANDBOX_USER=$(yq -r '.sandbox_user.name' "$PROFILE")
if getent passwd "$SANDBOX_USER" >/dev/null 2>&1 \
   && sudo -n -u "$SANDBOX_USER" true >/dev/null 2>&1; then
    SANDBOX_HOME=$(getent passwd "$SANDBOX_USER" | cut -d: -f6)
    USE_SANDBOX_USER=true
else
    if ! getent passwd "$SANDBOX_USER" >/dev/null 2>&1; then
        echo "claude-sandbox: warning — sandbox user '$SANDBOX_USER' does not exist." >&2
    else
        echo "claude-sandbox: warning — cannot sudo to '$SANDBOX_USER' non-interactively." >&2
        echo "  Is /etc/sudoers.d/claude-sandbox installed? (make install)" >&2
    fi
    echo "  Running in same-UID degraded mode (no separate principal; DEC-012 not in force)." >&2
    SANDBOX_HOME="$USER_HOME"
    USE_SANDBOX_USER=false
fi

IS_WSL=false; [ -d /mnt/wsl ] && IS_WSL=true

substitute() {
    sed -e "s|\${USER_HOME}|${USER_HOME}|g" \
        -e "s|\${SANDBOX_HOME}|${SANDBOX_HOME}|g" \
        -e "s|\${ACTIVE_PROJECT}|${ACTIVE_PROJECT}|g" \
        -e "s|\${INHERIT_TERM}|${INHERIT_TERM}|g" \
        -e "s|\${INHERIT_LANG}|${INHERIT_LANG}|g"
}

# Existence check for sandbox_home paths. Those live in claude-session's
# ~0750 home, which the wrapper (running as hactar during host-side prep)
# cannot traverse — so a plain `-e` would wrongly skip every claude-session-
# owned bind. Check as the sandbox user instead (DEC-012). Falls back to a
# plain `-e` in same-UID degraded mode.
sandbox_path_exists() {
    if [ "$USE_SANDBOX_USER" = true ]; then
        sudo -u "$SANDBOX_USER" test -e "$1"
    else
        [ -e "$1" ]
    fi
}

# Environment scrub (DEC-011/012): start from an empty env and set only what a
# session needs. For composed mode also assert srt's subprocess-env scrub so
# bwrap-internal Bash subprocesses don't inherit host credentials.
build_scrubbed_env() {
    SCRUB_ENV=(
        env -i
        "HOME=${SANDBOX_HOME}"
        "USER=${SANDBOX_USER}"
        # claude-session's own bin dirs first so composed/oauth (which run its
        # claude directly via this env, no bwrap re-setenv) resolve it.
        "PATH=${SANDBOX_HOME}/.local/bin:${SANDBOX_HOME}/.bun/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
        "TERM=${INHERIT_TERM}"
        "LANG=${INHERIT_LANG}"
    )
    if [ "$MODE" = "composed" ]; then
        SCRUB_ENV+=("CLAUDE_CODE_SUBPROCESS_ENV_SCRUB=1")
    fi
}

# Standalone bwrap-arg builder. 40s.15.3 refines this to fully share the
# profile schema with the 40s.15.2 settings emitter; for the skeleton it
# reuses the validated POC translation. Note: the DEC-012 identity switch is
# now sudo -u (above), so the POC's --uid/--gid remap is dropped here.
build_bwrap_args() {
    BWRAP_ARGS=()
    [ "$(yq -r '.environment.clearenv' "$PROFILE")" = "true" ] && BWRAP_ARGS+=(--clearenv)
    while IFS=$'\t' read -r var value; do
        [ -z "$var" ] && continue
        value=$(printf '%s' "$value" | substitute)
        BWRAP_ARGS+=(--setenv "$var" "$value")
    done < <(yq -r '.environment.set[] | [.var, .value] | @tsv' "$PROFILE")

    BWRAP_ARGS+=(
        --proc /proc --dev /dev --tmpfs /tmp --tmpfs "$SANDBOX_HOME"
        --symlink usr/bin /bin --symlink usr/lib /lib --symlink usr/lib64 /lib64
    )
    while IFS=$'\t' read -r src tgt when; do
        [ -z "$src" ] && continue
        [ "$when" = "wsl_only" ] && [ "$IS_WSL" = false ] && continue
        src=$(printf '%s' "$src" | substitute); tgt=$(printf '%s' "$tgt" | substitute)
        [ -e "$src" ] || { echo "claude-sandbox: skip ro-bind (missing): $src" >&2; continue; }
        BWRAP_ARGS+=(--ro-bind "$src" "$tgt")
    done < <(yq -r '.read_only[] | [.source, .target, (.when // "")] | @tsv' "$PROFILE")
    while IFS=$'\t' read -r src tgt; do
        [ -z "$src" ] && continue
        src=$(printf '%s' "$src" | substitute); tgt=$(printf '%s' "$tgt" | substitute)
        [ -e "$src" ] || { echo "claude-sandbox: skip bind (missing): $src" >&2; continue; }
        BWRAP_ARGS+=(--bind "$src" "$tgt")
    done < <(yq -r '.read_write[] | [.source, .target] | @tsv' "$PROFILE")
    while IFS=$'\t' read -r src tgt mode; do
        [ -z "$src" ] && continue
        src=$(printf '%s' "$src" | substitute); tgt=$(printf '%s' "$tgt" | substitute)
        sandbox_path_exists "$src" || { echo "claude-sandbox: skip sandbox_home bind (missing): $src" >&2; continue; }
        case "$mode" in
            rw)      BWRAP_ARGS+=(--bind    "$src" "$tgt") ;;
            *)       BWRAP_ARGS+=(--ro-bind "$src" "$tgt") ;;
        esac
    done < <(yq -r '.sandbox_home[] | [.source, .target, (.mode // "ro")] | @tsv' "$PROFILE")
    # Standalone network is ON/OFF only: bwrap has no L7 filtering, so it
    # cannot domain-allowlist the way srt does (composed mode) via its built-in
    # proxy. Domain-allowlisting for standalone is deferred to the DEC-013 SNI
    # egress proxy (ClaudeConfig-ciw.3) routed in by ClaudeConfig-40s.15.5.
    # Until then, `host` = full host network. The composed: profile section's
    # allowed_domains does NOT apply here — that drives srt only.
    case "$(yq -r '.network.policy' "$PROFILE")" in
        host)  BWRAP_ARGS+=(--unshare-all --share-net) ;;
        none)  BWRAP_ARGS+=(--unshare-all) ;;
        *)     echo "claude-sandbox: unsupported network policy" >&2; exit 1 ;;
    esac
    BWRAP_ARGS+=(--die-with-parent --hostname claude-sandbox --chdir "$ACTIVE_PROJECT")
}

# ── Dispatch ──────────────────────────────────────────────────────────────────

# Sync claude-session's claude to the host version if behind (40s.15.7). Real
# runs + separate-user only; skippable for offline / to avoid chasing frequent
# host auto-updates (each sync re-downloads the native binary).
if [ "$DRY_RUN" = false ] && [ "$USE_SANDBOX_USER" = true ] \
   && [ -z "${CLAUDE_SANDBOX_SKIP_VERSION_SYNC:-}" ]; then
    sync_claude_session_version
fi

# Mirror the host user's ~/.claude/{skills,agents,commands,scripts} into
# claude-session's home + set its scoped deny rules (40s.15.8). Real runs +
# separate-user only.
if [ "$DRY_RUN" = false ] && [ "$USE_SANDBOX_USER" = true ]; then
    assemble_claude_dir
fi

# Grant claude-session traversal+rwX on the active project (DEC-012 / 40s.15.9)
# before entering the sandbox, so the bind/access resolves. Real runs only
# (dry-run must not mutate ACLs); separate-user mode only (same-UID needs no
# ACL); NOT in oauth mode (it forces claude-session's home, has no project).
# Idempotent + fast on re-runs. Non-fatal: warn and continue on failure.
if [ "$DRY_RUN" = false ] && [ "$USE_SANDBOX_USER" = true ] && [ "$MODE" != "oauth" ]; then
    if acl_script="$(resolve_acl_script)"; then
        "$acl_script" --user "$SANDBOX_USER" --home-dir "$USER_HOME" \
            --project "$ACTIVE_PROJECT" >/dev/null \
            || echo "claude-sandbox: warning — project ACL grant failed; sandbox may not access $ACTIVE_PROJECT" >&2
    else
        echo "claude-sandbox: warning — ACL script not found; sandbox may not access $ACTIVE_PROJECT" >&2
    fi
fi

build_scrubbed_env

if [ "$MODE" = "oauth" ]; then
    # One-time OAuth bootstrap (ClaudeConfig-40s.15.10). Runs claude-session's
    # OWN claude bare (no srt/bwrap — the login/OAuth domains aren't on the
    # sandbox allowlist) but with cwd FORCED to claude-session's home, so no
    # caller-inherited cwd (the inherited-cwd leak) is ever in play. Requires
    # the separate user; degraded same-UID mode has no separate identity to
    # authenticate.
    if [ "$USE_SANDBOX_USER" != true ]; then
        echo "claude-sandbox --oauth: requires the '$SANDBOX_USER' user (run 'make provision' first)." >&2
        exit 1
    fi
    # shellcheck disable=SC2016  # $SBHOME/$@ expand in the bash -c subshell, by design
    CMD=("${SCRUB_ENV[@]}" "SBHOME=$SANDBOX_HOME" bash -c 'cd "$SBHOME" && exec claude "$@"' _ "$@")
elif [ "$MODE" = "composed" ]; then
    if [ -n "$SRT_SETTINGS_OVERRIDE" ]; then
        SRT_SETTINGS_FILE="$SRT_SETTINGS_OVERRIDE"
        [ -f "$SRT_SETTINGS_FILE" ] || {
            echo "claude-sandbox: CLAUDE_SANDBOX_SRT_SETTINGS not found: $SRT_SETTINGS_FILE" >&2; exit 1; }
    else
        [ -x "$EMITTER" ] || {
            echo "claude-sandbox: settings emitter not found: $EMITTER" >&2; exit 1; }
        # /tmp so the claude-session UID can read it; fixed per-user+profile
        # name, overwritten each run (Phase 1 single-session; Phase 3+
        # per-session worktrees need a per-session path).
        SRT_SETTINGS_FILE="${TMPDIR:-/tmp}/claude-sandbox-srt.$(id -u).${PROFILE_NAME}.json"
        ACTIVE_PROJECT="$ACTIVE_PROJECT" SANDBOX_HOME="$SANDBOX_HOME" \
            "$EMITTER" "$PROFILE" > "$SRT_SETTINGS_FILE"
        chmod 0644 "$SRT_SETTINGS_FILE"
    fi
    # Deterministic cwd: cd to the project rather than relying on sudo's
    # inherited cwd (cwd-guard + 40s.15.10). Mirrors standalone's bwrap --chdir.
    # shellcheck disable=SC2016  # $ACTIVE_PROJECT/$0/$@ expand in the bash -c subshell, by design
    CMD=("${SCRUB_ENV[@]}" "ACTIVE_PROJECT=$ACTIVE_PROJECT" \
         bash -c 'cd "$ACTIVE_PROJECT" && exec srt --settings "$0" claude "$@"' \
         "$SRT_SETTINGS_FILE" "$@")
else
    build_bwrap_args
    CMD=("${SCRUB_ENV[@]}" bwrap "${BWRAP_ARGS[@]}" -- claude "$@")
fi

# Wrap with sudo -u when the identity switch is in force.
if [ "$USE_SANDBOX_USER" = true ]; then
    FINAL=(sudo -u "$SANDBOX_USER" "${CMD[@]}")
else
    FINAL=("${CMD[@]}")
fi

if [ "$DRY_RUN" = true ]; then
    echo "claude-sandbox: mode=$MODE profile=$PROFILE_NAME identity=$([ "$USE_SANDBOX_USER" = true ] && echo "$SANDBOX_USER" || echo "same-uid(degraded)")"
    printf 'exec:'; printf ' %q' "${FINAL[@]}"; printf '\n'
    exit 0
fi

exec "${FINAL[@]}"
