# sandbox/justfile — sandbox-domain install + provision + smoke recipes.
# Imported flat into the project root justfile (ClaudeConfig-zdk / F-just1).
# Recipes here are directly callable from the project root, prefixed with
# their domain (`just install-sandbox`, `just provision`, etc.).
#
# Variables (prefix, bin_dir, share_dir, profile_dir, etc_dir) are
# declared in the root justfile and visible via Just's flat-import.

# Install all sandbox-domain artifacts to host paths.
install-sandbox:
    #!/usr/bin/env bash
    set -euo pipefail
    install -d -m 0755 "{{bin_dir}}"
    install -d -m 0755 "{{share_dir}}/scripts"
    install -d -m 0755 "{{profile_dir}}"
    install -d -m 0755 "{{etc_dir}}"
    install -m 0755 sandbox/bin/claude-sandbox                   "{{bin_dir}}/claude-sandbox"
    install -m 0755 sandbox/bin/claude-sandbox-emit-srt-settings "{{bin_dir}}/claude-sandbox-emit-srt-settings"
    install -m 0644 sandbox/profiles/default.yaml                "{{profile_dir}}/default.yaml"
    install -m 0644 claude/settings/managed-settings.json        "{{etc_dir}}/managed-settings.json"
    install -m 0755 sandbox/scripts/_hooks-manifest.sh           "{{share_dir}}/scripts/_hooks-manifest.sh"
    install -m 0755 sandbox/scripts/setup-claude-session-acls.sh "{{share_dir}}/scripts/setup-claude-session-acls.sh"
    install -m 0755 sandbox/scripts/provision-claude-session.sh  "{{share_dir}}/scripts/provision-claude-session.sh"
    install -m 0755 sandbox/scripts/provision-claude-egress.sh   "{{share_dir}}/scripts/provision-claude-egress.sh"
    install -m 0755 sandbox/scripts/install-dev-tools.sh         "{{share_dir}}/scripts/install-dev-tools.sh"
    echo "✓ sandbox installed:"
    echo "    {{bin_dir}}/claude-sandbox"
    echo "    {{bin_dir}}/claude-sandbox-emit-srt-settings"
    echo "    {{profile_dir}}/default.yaml"
    echo "    {{etc_dir}}/managed-settings.json"
    echo "    {{share_dir}}/scripts/{_hooks-manifest,setup-claude-session-acls,provision-claude-session,provision-claude-egress,install-dev-tools}.sh"

# Reverse install-sandbox (sandbox artifacts only; does NOT unprovision).
uninstall-sandbox:
    #!/usr/bin/env bash
    set -euo pipefail
    declare -a paths=(
        "{{bin_dir}}/claude-sandbox"
        "{{bin_dir}}/claude-sandbox-emit-srt-settings"
        "{{profile_dir}}/default.yaml"
        "{{etc_dir}}/managed-settings.json"
        "{{share_dir}}/scripts/_hooks-manifest.sh"
        "{{share_dir}}/scripts/setup-claude-session-acls.sh"
        "{{share_dir}}/scripts/provision-claude-session.sh"
        "{{share_dir}}/scripts/provision-claude-egress.sh"
        "{{share_dir}}/scripts/install-dev-tools.sh"
    )
    for f in "${paths[@]}"; do
        if [ -e "$f" ]; then
            echo "  rm $f"
            rm -f "$f"
        fi
    done
    echo "✓ sandbox uninstalled"

# Provision claude-session + claude-egress (DEC-013); sudo-mediated.
provision: provision-egress
    @echo "Provisioning claude-session (will prompt for sudo) ..."
    {{share_dir}}/scripts/provision-claude-session.sh \
        --acl-script {{share_dir}}/scripts/setup-claude-session-acls.sh

# Reverse `just provision` (egress policy/cred dirs preserved as operator data).
unprovision: unprovision-egress
    @echo "Un-provisioning claude-session (will prompt for sudo) ..."
    {{share_dir}}/scripts/provision-claude-session.sh --uninstall \
        --acl-script {{share_dir}}/scripts/setup-claude-session-acls.sh

# Provision claude-egress UID + policy/credential dirs (DEC-013).
provision-egress:
    @echo "Provisioning claude-egress (will prompt for sudo) ..."
    {{share_dir}}/scripts/provision-claude-egress.sh

# Reverse `just provision-egress` (preserves operator-authored policy/cred files).
unprovision-egress:
    @echo "Un-provisioning claude-egress (will prompt for sudo) ..."
    {{share_dir}}/scripts/provision-claude-egress.sh --uninstall

# Reverse `just provision-egress` AND remove policy/credential dirs + contents.
unprovision-egress-purge:
    @echo "Un-provisioning claude-egress with --purge (will prompt for sudo) ..."
    {{share_dir}}/scripts/provision-claude-egress.sh --uninstall --purge

# Run the Phase 1 wrapper smoke test (composed + standalone modes).
smoke:
    sandbox/scripts/smoke-test.sh

# Build manpages from sandbox/man/*.scd via scdoc (ClaudeConfig-4g0).
# Outputs are placed alongside their .scd sources; install-man-sandbox
# copies them into ${PREFIX}/share/man/<section>/.
build-man-sandbox:
    #!/usr/bin/env bash
    set -euo pipefail
    if ! command -v scdoc >/dev/null 2>&1; then
        echo "build-man-sandbox: scdoc not installed (apt-get install scdoc)" >&2
        exit 1
    fi
    shopt -s nullglob
    built=0
    for src in sandbox/man/*.scd; do
        out="${src%.scd}"
        scdoc < "$src" > "$out"
        echo "  ✓ $out"
        built=$((built + 1))
    done
    if [ "$built" -eq 0 ]; then
        echo "  (no .scd sources under sandbox/man/)"
    fi

# Install sandbox manpages to ${PREFIX}/share/man/man<section>/.
install-man-sandbox: build-man-sandbox
    #!/usr/bin/env bash
    set -euo pipefail
    shopt -s nullglob
    for built in sandbox/man/*.[1-8]; do
        section="${built##*.}"
        name="$(basename "$built")"
        target_dir="{{prefix}}/share/man/man${section}"
        install -d -m 0755 "$target_dir"
        install -m 0644 "$built" "${target_dir}/${name}"
        echo "  ✓ ${target_dir}/${name}"
    done

# Uninstall sandbox manpages.
uninstall-man-sandbox:
    #!/usr/bin/env bash
    set -euo pipefail
    shopt -s nullglob
    for built in sandbox/man/*.[1-8]; do
        section="${built##*.}"
        name="$(basename "$built")"
        target="{{prefix}}/share/man/man${section}/${name}"
        if [ -e "$target" ]; then
            echo "  rm $target"
            rm -f "$target"
        fi
    done

# Verify installed sandbox files + wrapper version.
verify-sandbox:
    #!/usr/bin/env bash
    set -euo pipefail
    echo "Verifying sandbox install ..."
    declare -a paths=(
        "{{bin_dir}}/claude-sandbox"
        "{{bin_dir}}/claude-sandbox-emit-srt-settings"
        "{{profile_dir}}/default.yaml"
        "{{etc_dir}}/managed-settings.json"
        "{{share_dir}}/scripts/_hooks-manifest.sh"
        "{{share_dir}}/scripts/setup-claude-session-acls.sh"
        "{{share_dir}}/scripts/provision-claude-session.sh"
        "{{share_dir}}/scripts/provision-claude-egress.sh"
    )
    for f in "${paths[@]}"; do
        if [ -e "$f" ]; then
            echo "  ✓ present: $f"
        else
            echo "  ✗ MISSING: $f"
        fi
    done
    if [ -x "{{bin_dir}}/claude-sandbox" ]; then
        echo ""
        echo "Wrapper version:"
        "{{bin_dir}}/claude-sandbox" --version 2>&1 | sed 's/^/  /'
    fi

# ── Egress broker (Go production binary; ClaudeConfig-1ic slice 6) ──

# Build the Go egress broker binary into sandbox/broker/bin/ (gitignored).
build-egress-broker:
    #!/usr/bin/env bash
    set -euo pipefail
    cd sandbox/broker
    mkdir -p bin
    go build -trimpath -ldflags='-s -w' -o bin/claude-egress-broker ./cmd/claude-egress-broker
    sz=$(wc -c < bin/claude-egress-broker)
    echo "✓ built sandbox/broker/bin/claude-egress-broker (${sz} bytes)"

# Install the Go egress broker binary + systemd units. Sudo-mediated.
install-egress-broker: build-egress-broker
    #!/usr/bin/env bash
    set -euo pipefail
    echo "Installing claude-egress-broker (will prompt for sudo) ..."
    sudo install -d -m 0755 "{{sbin_dir}}"
    sudo install -d -m 0755 "{{systemd_dir}}"
    sudo install -m 0755 sandbox/broker/bin/claude-egress-broker  "{{sbin_dir}}/claude-egress-broker"
    sudo install -m 0755 sandbox/scripts/prime-egress-broker.sh   "{{sbin_dir}}/prime-egress-broker"
    sudo install -m 0755 sandbox/scripts/claude-egress-broker-healthcheck.sh \
                                                                  "{{sbin_dir}}/claude-egress-broker-healthcheck"
    sudo install -m 0644 sandbox/systemd/claude-egress-broker.socket  "{{systemd_dir}}/claude-egress-broker.socket"
    sudo install -m 0644 sandbox/systemd/claude-egress-broker.service "{{systemd_dir}}/claude-egress-broker.service"
    echo "✓ installed:"
    echo "    {{sbin_dir}}/claude-egress-broker"
    echo "    {{sbin_dir}}/prime-egress-broker"
    echo "    {{sbin_dir}}/claude-egress-broker-healthcheck"
    echo "    {{systemd_dir}}/claude-egress-broker.{socket,service}"
    echo ""
    echo "Next steps:"
    echo "  1. Substitute CLAUDE_SESSION_UID in the service unit:"
    echo "       sudo systemctl edit claude-egress-broker.service   # add ExecStart drop-in"
    echo "  2. sudo systemctl daemon-reload"
    echo "  3. sudo prime-egress-broker   # primes gpg-agent + seeds sentinel (ClaudeConfig-bd5)"
    echo "  4. sudo systemctl enable --now claude-egress-broker.socket"

# Prime the claude-egress gpg-agent with the broker key's passphrase (ClaudeConfig-bd5). Sudo-mediated.
prime-egress-broker *ARGS:
    sudo "{{sbin_dir}}/prime-egress-broker" {{ARGS}}

# Reverse install-egress-broker (operator must `systemctl disable --now` first).
uninstall-egress-broker:
    #!/usr/bin/env bash
    set -euo pipefail
    echo "Uninstalling claude-egress-broker (will prompt for sudo) ..."
    declare -a paths=(
        "{{sbin_dir}}/claude-egress-broker"
        "{{sbin_dir}}/prime-egress-broker"
        "{{sbin_dir}}/claude-egress-broker-healthcheck"
        "{{systemd_dir}}/claude-egress-broker.socket"
        "{{systemd_dir}}/claude-egress-broker.service"
    )
    for f in "${paths[@]}"; do
        if [ -e "$f" ]; then
            echo "  rm $f"
            sudo rm -f "$f"
        fi
    done
    echo "✓ claude-egress-broker uninstalled (operator should run: sudo systemctl daemon-reload)"

# Run Go test suite for the egress broker.
test-egress-broker:
    cd sandbox/broker && go test ./...

# Run go vet across the broker module.
vet-egress-broker:
    cd sandbox/broker && go vet ./...

# ── Egress SNI-passthrough proxy (Go production binary; ClaudeConfig-ciw.3) ──

# Build the Go egress proxy binary into sandbox/proxy/bin/ (gitignored).
build-egress-proxy:
    #!/usr/bin/env bash
    set -euo pipefail
    cd sandbox/proxy
    mkdir -p bin
    go build -trimpath -ldflags='-s -w' -o bin/claude-egress-proxy ./cmd/claude-egress-proxy
    sz=$(wc -c < bin/claude-egress-proxy)
    echo "✓ built sandbox/proxy/bin/claude-egress-proxy (${sz} bytes)"

# Install the Go egress proxy binary + systemd units. Sudo-mediated.
install-egress-proxy: build-egress-proxy
    #!/usr/bin/env bash
    set -euo pipefail
    echo "Installing claude-egress-proxy (will prompt for sudo) ..."
    sudo install -d -m 0755 "{{sbin_dir}}"
    sudo install -d -m 0755 "{{systemd_dir}}"
    sudo install -m 0755 sandbox/proxy/bin/claude-egress-proxy  "{{sbin_dir}}/claude-egress-proxy"
    sudo install -m 0644 sandbox/systemd/claude-egress-proxy.socket  "{{systemd_dir}}/claude-egress-proxy.socket"
    sudo install -m 0644 sandbox/systemd/claude-egress-proxy.service "{{systemd_dir}}/claude-egress-proxy.service"
    echo "✓ installed:"
    echo "    {{sbin_dir}}/claude-egress-proxy"
    echo "    {{systemd_dir}}/claude-egress-proxy.{socket,service}"
    echo ""
    echo "Next steps:"
    echo "  1. Install at least one policy file under /etc/claude-config/egress-proxy/"
    echo "     (sample: sandbox/egress-proxy/anthropic-cdn.yaml)"
    echo "  2. sudo systemctl daemon-reload"
    echo "  3. sudo systemctl enable --now claude-egress-proxy.socket"

